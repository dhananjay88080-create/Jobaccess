NODE_ENV=development
APP_URL=http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017/jobaccess

# Admin authentication
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123
JWT_SECRET=replace_with_a_long_random_secret_key

# Safe RSS feeds only (comma-separated)
RSS_FEED_URLS=https://example.gov/jobs-feed.xml,https://example-state.gov/recruitment/rss.xml
PUBLIC_API_SOURCES=

# Optional compliant HTML adapter (ONLY for explicitly permitted domains)
ENABLE_HTML_SOURCE_IMPORT=false
ALLOWED_HTML_SOURCE_DOMAINS=
HTML_SOURCE_USER_AGENT=JobAccessBot/1.0 (+http://localhost:3000)
HTML_SOURCE_CONFIG_JSON=[]

# Scheduler (every 6 hours by default)
CRON_ENABLED=true
CRON_RSS_SCHEDULE=0 */6 * * *
CRON_API_KEY=replace_with_internal_cron_api_key

# AdSense (optional)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_TOP_SLOT=
NEXT_PUBLIC_ADSENSE_IN_CONTENT_SLOT=
NEXT_PUBLIC_ADSENSE_SIDEBAR_SLOT=

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
